<div class="xmov" id="_xpdm"><div class="xmob"><div class="xmoh"><h2>Shipments Left to Stow</h2><button class="xmoc" id="_cl_xpdm">×</button></div><div class="xmbd"><div style="margin-bottom:8px;"><label style="font-size:.82rem;">Cycle:<select id="_xpdcf" style="padding:3px 7px;border-radius:4px;border:1px solid var(--bdr);margin-left:4px;"><option value="ALL">All</option><option value="CYCLE_1">CYCLE 1</option><option value="CYCLE_2">CYCLE 2</option><option value="AD_HOC_1">AD HOC 1</option><option value="SAME_DAY">SAME DAY</option></select></label></div><div id="_xpdb"></div></div></div></div>`;

var wrap=document.createElement('div');wrap.id='_sd';wrap.innerHTML=H;document.body.appendChild(wrap);

// ── CORE LOGIC ───────────────────────────────────────────────────────────────
var BASE=window.location.origin;
var stowers=[],idleT={},removed=new Set(JSON.parse(localStorage.getItem('_xrm')||'[]'));
var paused=false,tmr,tv=30,pkgC={},prevFsaf={},notifA=new Set(JSON.parse(localStorage.getItem('_xna')||'[]'));
var flow={i:{v:0,t:{},ts:null},s:{v:0,ts:null}};
var cycleId=null,lastDb=0,dbC={};
// ✅ FIX: renamed 'sd' to 'sortDir' to avoid collision with showDb function
var sc=4,sortDir='desc';
var station=localStorage.getItem('stowStation')||'DWP2';

function g(id){return document.getElementById(id);}
function toast(m){var t=g('_xt');if(!t)return;t.textContent=m;t.style.display='block';setTimeout(function(){t.style.display='none';},2500);}
function fmt(ms){if(ms<=0)return'0:00';var s=Math.floor(ms/1000);return Math.floor(s/60)+':'+(s%60<10?'0':'')+(s%60);}
function cyc(){return g('_xcy')?g('_xcy').value:'CYCLE_1';}
function om(id){var e=g(id);if(e)e.classList.add('show');}
function cm(id){var e=g(id);if(e)e.classList.remove('show');}

var _sccHeaders = {};
var _apiKey = null;
(function(){
  var origFetch = window.fetch;
  window.fetch = function(url, opts){
    if(url && String(url).includes('amazon') && opts && opts.headers){
      var h = opts.headers;
      if(h instanceof Headers){
        h.forEach(function(v,k){
          if(k.toLowerCase()==='x-api-usage-key'){_apiKey=v;_sccHeaders[k]=v;}
          else if(k.toLowerCase().startsWith('x-')){_sccHeaders[k]=v;}
        });
      } else if(typeof h === 'object'){
        if(h['X-Api-Usage-Key']){_apiKey=h['X-Api-Usage-Key'];_sccHeaders['X-Api-Usage-Key']=_apiKey;}
        if(h['x-api-usage-key']){_apiKey=h['x-api-usage-key'];_sccHeaders['X-Api-Usage-Key']=_apiKey;}
      }
    }
    return origFetch.apply(this, arguments);
  };
  var origOpen = XMLHttpRequest.prototype.open;
  var origSetHeader = XMLHttpRequest.prototype.setRequestHeader;
  XMLHttpRequest.prototype.open = function(method, url){
    this._xurl = url;
    return origOpen.apply(this, arguments);
  };
  XMLHttpRequest.prototype.setRequestHeader = function(k, v){
    if(k && k.toLowerCase()==='x-api-usage-key'){
      _apiKey=v;
      _sccHeaders['X-Api-Usage-Key']=v;
    }
    return origSetHeader.apply(this, arguments);
  };
})();

function api(rp,pn,rb,cb){
  var body=JSON.stringify({resourcePath:rp,httpMethod:'post',processName:pn,requestBody:rb});
  var key=_apiKey||_sccHeaders['X-Api-Usage-Key']||_sccHeaders['x-api-usage-key']
    ||'scc-boson-api-k8x7m2n4p9q1r3s5:1776808103761:SMszXG+e4hj9HfXeAXe5012G+BVpAzu7tYxc6+N0siA=';

  function doRequest(tries){
    GM_xmlhttpRequest({
      method:'POST',
      url:BASE+'/station/proxyapigateway/data',
      headers:{
        'Content-Type':'application/json',
        'Accept':'*/*',
        'X-Requested-With':'XMLHttpRequest',
        'X-Api-Usage-Key':key
      },
      data:body,
      withCredentials:true,
      onload:function(r){
        if(r.status===200){
          try{cb(null,JSON.parse(r.responseText));}
          catch(e){cb(e,null);}
        } else if(r.status===403&&tries>0){
          setTimeout(function(){doRequest(tries-1);},3000);
        } else {
          cb(new Error('HTTP '+r.status),null);
        }
      },
      onerror:function(){cb(new Error('net'),null);}
    });
  }
  doRequest(3);
}

function xget(url,cb){
  GM_xmlhttpRequest({
    method:'GET',
    url:url,
    headers:{'Accept':'application/json','X-Requested-With':'XMLHttpRequest'},
    withCredentials:true,
    onload:function(r){
      if(r.status===200){try{cb(null,JSON.parse(r.responseText));}catch(e){cb(e,null);}}
      else cb(new Error('HTTP '+r.status),null);
    },
    onerror:function(){cb(new Error('net'),null);}
  });
}

function startTimer(){if(tmr)clearInterval(tmr);tv=30;tmr=setInterval(function(){if(paused)return;tv--;var e=g('_xtv');if(e)e.textContent=tv;if(tv<=0){fa();tv=30;}},1000);}

function stealFreshKey(onDone){
  if(_apiKey){onDone();return;}
  var done=false;
  var finish=function(){if(!done){done=true;onDone();}};
  var waited=0;
  var poll=setInterval(function(){
    waited+=200;
    if(_apiKey||waited>=5000){
      clearInterval(poll);
      finish();
    }
  },200);
}

function fa(){
  if(paused||!station)return;tv=30;var e=g('_xtv');if(e)e.textContent=tv;pkgC={};
  toast('Initialisation...');
  stealFreshKey(function(){
    toast('Fetching...');
    pullStow();pullActive();pullAisle();pullDwell();pullInduct();pullSort();checkDb();
  });
}

function pullStow(){
  var rb={fieldsRequired:['NAME','STATUS','PERFORMANCE','LOCATION'],filters:{NODE:[station]}};
  var c=cyc();if(c!=='ALL')rb.filters.CYCLE=[c];
  api('svs/associates/data','stow',rb,function(err,data){
    if(err||!data||!data.associates){stowers=[];renderAll();return;}
    var logins=[...new Set(data.associates.map(function(a){return a.alias.split('@')[0].toLowerCase();}))].join(',');
    if(!logins){stowers=[];renderAll();return;}
    var tgt=parseInt(g('_xtgt')?g('_xtgt').value:365)||365;
    xget('https://fclearning.amazon.com/fcl/employeeSearch?type=employeeBatch&query='+logins,function(err2,emp){
      var sm=new Map((emp||[]).map(function(e){return[e.employeeLogin.toLowerCase(),{name:e.employeeName,shift:e.shiftPattern}];}));
      stowers=data.associates.map(function(a){
        var login=a.alias.split('@')[0];
        var info=sm.get(login.toLowerCase())||{name:login,shift:'Unknown'};
        var name=info.name&&info.name.includes(',')?info.name.split(',').reverse().join(' ').trim():(info.name||login);
        var loc=a.location||'N/A';
        var shift='OTHER';if(info.shift&&info.shift.includes('D'))shift='DAYS';else if(info.shift&&info.shift.includes('N'))shift='NIGHTS';
        return{name:name,login:login,shift:shift,uph:a.performance.pph>0?Math.round(a.performance.pph):0,
          totalStowed:a.performance.stowedCount,fsaf:a.performance.fsaf,fsafDpmo:a.performance.fsafDpmo,
          lastStow:a.performance.localMaxScanTime,target:tgt,status:a.status,location:loc,cluster:loc.charAt(0).toUpperCase()};
      });
      updateIdle(stowers);renderAll();checkFsaf(stowers);toast('✅ Refreshed');
    });
  });
}

function pullDwell(){
  var rb={nodeId:station,view:'DWELLING_VIEW',filters:[{__type:'TermFilter:http://internal.amazon.com/coral/com.amazon.oculusservice.model.filter/',filterMap:{SHIPMENT_TYPE:['Delivery']}},{__type:'RangeFilter:http://internal.amazon.com/coral/com.amazon.oculusservice.model.filter/',filterMap:{}}],leg:'FORWARD'};
  api('/os/getDwellingPackageData','oculus',rb,function(err,data){
    if(err||!data)return;
    var t={m:0,it:0,h:0,ar:0,rc:0,ind:0,bf:0,ps:0};
    var ob=['DS -> Customer','DS -> XPT'],ib=['Manifested','In Transit','Held','Arrived','Problem Solve','Received'];
    var sp=['AD_HOC_1','CYCLE_SD_A','CYCLE_SD_C','CYCLE_SD_D','HIGH_VALUE','RTS_1','SAME_DAY'],sel=cyc();
    (data.metricResult||[]).forEach(function(m){
      var st=m.packageStatus,dir=m.metaDataMap&&m.metaDataMap.direction,cm2=m.columnToViewDataMap;
      if(st==='In Transit'&&ob.includes(dir))return;
      var count=0,sf=sp.includes(sel)||!ib.includes(st);
      if(sf&&sel!=='ALL'){var k=Object.keys(cm2).find(function(k2){return sel==='NO_CYCLE'?(k2==='NO_CYCLE'||k2===''||k2===null):(k2.startsWith(sel+'-')||k2===sel);});if(k)count=parseInt(cm2[k]&&cm2[k].value||cm2[k]||0);}
      else{for(var k in cm2)count+=parseInt(cm2[k]&&cm2[k].value||cm2[k]||0);}
      if(st==='Stow Buffered')t.bf+=count;else if(st==='Stow Problem Solve')t.ps+=count;else if(st==='Inducted')t.ind+=count;
      else if(st==='Received')t.rc+=count;else if(st==='Arrived'||st==='Problem Solve')t.ar+=count;
      else if(st==='Held')t.h+=count;else if(st==='Manifested')t.m+=count;else if(st==='In Transit')t.it+=count;
    });
    var p=t.ind+t.bf+t.ps;
    var s2=function(id,v){var e=g(id);if(e)e.textContent=v.toLocaleString();};
    s2('_xpm',t.m);s2('_xpit',t.it);s2('_xph',t.h);s2('_xpa',t.ar);s2('_xpr',t.rc);
    s2('_xpps',p);s2('_xpi2',t.ind);s2('_xpb',t.bf);s2('_xpps2',t.ps);
  });
}

function pullInduct(){
  var tried=0;
  var tryApi=function(pn){
    api('/ivs/getLocationMetric',pn,{nodeId:station},function(err,data){
      if(!err&&data&&data.locationInsightList){
        flow.i={v:0,t:{},ts:new Date()};
        (data.locationInsightList||[]).forEach(function(l){
          if(l.inductRate>0){flow.i.t[l.locationName]={r:l.inductRate,v:l.volumeInducted||0};flow.i.v+=l.inductRate;}
        });
        updateFlow();
      } else if(++tried<3){
        var names=['induct','ivs','stow'];
        tryApi(names[tried]);
      }
    });
  };
  tryApi('induct');
}

function pullSort(){
  var rb={nodeId:station,groupBy:'Node',filters:{Cycle:[cyc()==='ALL'?'CYCLE_1':cyc()]},metricList:['SORT_RATE_ACTUAL']};
  var tried=0;
  var tryApi=function(pn){
    api('/ivs/getPackageMetric',pn,rb,function(err,data){
      if(!err&&data&&data.groupedPackageMetrics){
        var r=data.groupedPackageMetrics.SORT_RATE_ACTUAL||{};
        flow.s.v=Math.round(r[station]!=null?r[station]:Object.values(r)[0]||0);
        flow.s.ts=new Date();
        updateFlow();
      } else if(++tried<3){
        var names=['sort','ivs','induct'];
        tryApi(names[tried]);
      }
    });
  };
  tryApi('sort');
}

function updateFlow(){
  var ie=g('_xir'),se=g('_xsr'),tl=g('_xtrl'),up=g('_xfu');if(!ie)return;
  if(up)up.textContent='Updated: '+(flow.i.ts||new Date()).toLocaleTimeString('en-IE');
  ie.textContent=flow.i.v>0?flow.i.v.toLocaleString()+'/hr':'--/hr';ie.style.color=flow.i.v>0?'#FF9900':'var(--err)';
  se.textContent=flow.s.v>0?flow.s.v.toLocaleString()+'/hr':'--/hr';se.style.color=flow.s.v>0?'#FF9900':'var(--err)';
  var sorted=Object.entries(flow.i.t).sort();
  if(tl)tl.innerHTML=sorted.length>0?sorted.filter(function(x){return x[1].r>0;}).map(function(x){return'<div style="display:flex;justify-content:space-between;padding:4px 2px;border-bottom:1px solid var(--bdr);font-size:.78rem;"><span style="font-weight:600;">'+x[0]+'</span><span>'+x[1].r.toLocaleString()+'/hr <span style="color:#999;">'+x[1].v.toLocaleString()+' pkgs</span></span></div>';}).join(''):'<em style="color:#999;font-size:.76rem;">No active induct tables</em>';
}

function pullAisle(){
  var c=cyc(),tG=parseInt(g('_xtg')?g('_xtg').value:1)||1,tY=parseInt(g('_xty')?g('_xty').value:21)||21,tO=parseInt(g('_xto')?g('_xto').value:41)||41,tR=parseInt(g('_xtr')?g('_xtr').value:61)||61;
  var cls=['A','B','C','D','E','F','G'],done=0,res=[];
  cls.forEach(function(cl,i){
    var rb={groupBy:'AISLE',filters:{NODE:[station],CLUSTER:[cl]},metrics:['CURRENT_INDUCTED_COUNT','CURRENT_STOWED_COUNT','CURRENT_STOW_BUFFERED_COUNT']};
    if(c!=='ALL')rb.filters.CYCLE=[c];
    api('svs/packages/metrics','stow',rb,function(err,data){
      res[i]={cl:cl,data:(!err&&data)?data.groupedPackageMetrics||{}:{}};
      if(++done===cls.length)renderAisle(res,tG,tY,tO,tR);
    });
  });
}

function renderAisle(res,tG,tY,tO,tR){
  var grid=g('_xaig');if(!grid)return;grid.innerHTML='';var red=0,cs={};
  res.forEach(function(item){
    var cl=item.cl,data=item.data,p={};
    for(var a in data){var px=a.charAt(0),n=parseInt(a.substring(1));if(!isNaN(n)&&px===cl){var st2=n%2===0?n-1:n,k=cl+st2+'-'+cl+(st2+1);if(!p[k])p[k]={i:0,b:0,s:0};var m=data[a];p[k].i+=m.currentInductedCount||0;p[k].b+=m.currentStowBufferedCount||0;p[k].s+=m.currentStowedCount||0;}}
    var pairs=Object.keys(p).filter(function(k){return(p[k].i+p[k].b+p[k].s)>0;}).sort(function(a,b){return parseInt(a.split('-')[0].substring(1))-parseInt(b.split('-')[0].substring(1));});
    if(!pairs.length)return;
    var cc=function(v){return v>=tR?'xcr':v>=tO?'xco':v>=tY?'xcy':v>=tG?'xcg':'';};
    var ti=0,tb=0,ts2=0;
    var rows=pairs.map(function(k){var d=p[k];ti+=d.i;tb+=d.b;ts2+=d.s;cs[k]={b:d.b};if(d.b>=tR)red++;
      var a1=k.split('-')[0],a2=k.split('-')[1];
      var hs=stowers.some(function(s2){return s2.status==='ACTIVE'&&(s2.location===a1||s2.location===a2);});
      return'<tr data-pair="'+k+'" style="cursor:pointer;"><td class="xan '+(hs?'xhs':'')+'">'+k+'</td><td class="'+cc(d.i)+'">'+d.i+'</td><td class="'+cc(d.b)+'" data-action="fpa" data-pair2="'+k+'" style="cursor:pointer;">'+d.b+'</td><td>'+d.s+'</td></tr>';
    }).join('');
    var tot=ti+tb+ts2,comp=tot>0?Math.round(ts2/tot*100):100;
    var col=document.createElement('div');col.className='xaw';
    col.innerHTML='<div class="xah">CLUSTER '+cl+'</div><table><thead><tr><th>Aisle</th><th>Inducted</th><th>Buffered</th><th>Stowed</th></tr></thead><tbody>'+rows+'</tbody></table><div class="xas"><div class="xab"><div class="xl">Active</div><div class="xv" id="_xas'+cl+'">0</div></div><div class="xab"><div class="xl">Pending</div><div class="xv">'+(ti+tb).toLocaleString()+'</div></div><div class="xab"><div class="xl">Compliance</div><div class="xv">'+comp+'%</div></div></div>';
    grid.appendChild(col);
  });
  // ✅ Attach event listeners to aisle rows
  grid.querySelectorAll('tr[data-pair]').forEach(function(row){
    row.addEventListener('click', function(e){
      if(e.target.dataset.action==='fpa'){e.stopPropagation();fpa(e.target.dataset.pair2);return;}
      sad(row.dataset.pair);
    });
  });
  var rb=g('_xrac');if(rb)rb.textContent=red;
  var ab=g('_xasb');if(ab)ab.style.borderColor=red>0?'var(--err)':'var(--bdr)';
  notifA.forEach(function(p){if(!cs[p]||cs[p].b<tR)notifA.delete(p);});
  for(var p in cs){if(cs[p].b>=tR&&!notifA.has(p)){notif('xna',null,'Aisle Needs Support: '+p,'Buffer: <strong>'+cs[p].b+'</strong>',function(){sas();});notifA.add(p);}}
  localStorage.setItem('_xna',JSON.stringify([...notifA]));
}

function pullActive(){
  var rb={groupBy:'CLUSTER',filters:{NODE:[station]},metrics:['ACTIVE_ASSOCIATE_COUNT']};
  var c=cyc();if(c!=='ALL')rb.filters.CYCLE=[c];
  api('svs/associates/metrics','stow',rb,function(err,data){
    if(err||!data)return;
    (data.associateMetricsGroupList||[]).forEach(function(item){var e=g('_xas'+item.displayLabel);if(e)e.textContent=Math.round(item.associateMetrics.activeCount||0);});
  });
}

function renderAll(){
  renderTop();renderTable();updateFlow();
  var e=g('_xpst');if(e)e.textContent=stowers.reduce(function(s2,a){return s2+a.totalStowed;},0).toLocaleString();
  popAF();
}

function renderTop(){
  var top=stowers.filter(function(p){return!removed.has(p.login);}).sort(function(a,b){return b.totalStowed-a.totalStowed||b.uph-a.uph;}).slice(0,10);
  var el2=g('_xtpl');if(!el2)return;
  el2.innerHTML=top.map(function(p,i){return'<li class="xpi" data-login="'+p.login+'"><span class="xpr">#'+(i+1)+'</span><img src="https://internal-cdn.amazon.com/badgephotos.amazon.com/?login='+p.login+'" onerror="this.style.display=\'none\'"><div style="flex-grow:1;"><div class="xpn">'+p.name+'</div><div class="xpl2">'+p.login+(p.status!=='ACTIVE'?' (Inactive)':'')+'</div></div><div class="xpst"><div><strong>'+p.totalStowed.toLocaleString()+'</strong><span>Stowed</span></div><div><strong>'+p.uph+'</strong><span>UPH</span></div></div></li>';}).join('');
  // ✅ Attach click events
  el2.querySelectorAll('.xpi').forEach(function(li){
    li.addEventListener('click', function(){sas2(li.dataset.login);});
  });
}

function renderTable(col,dir){
  if(col!==undefined)sc=col;if(dir!==undefined)sortDir=dir;
  var cl=g('_xcf')?g('_xcf').value:'ALL',al=g('_xaf')?g('_xaf').value:'ALL',ao=g('_xao')?g('_xao').checked:false;
  var data=stowers.filter(function(s2){return(cl==='ALL'||s2.cluster===cl||(cl==='OTHER'&&['A','B','C','D','E','F','G'].indexOf(s2.cluster)===-1))&&(al==='ALL'||s2.location===al)&&(!ao||s2.status==='ACTIVE');});
  var keys=['name','login','location','uph','totalStowed','lastStow','liveIdle','shift'];
  data.sort(function(a,b){var vA=keys[sc]==='liveIdle'?(a.lastStow>0?Date.now()-a.lastStow:0):(a[keys[sc]]||0),vB=keys[sc]==='liveIdle'?(b.lastStow>0?Date.now()-b.lastStow:0):(b[keys[sc]]||0);if(typeof vA==='number')return sortDir==='asc'?vA-vB:vB-vA;return sortDir==='asc'?String(vA).localeCompare(String(vB)):String(vB).localeCompare(String(vA));});
  document.querySelectorAll('#_xpt thead th').forEach(function(th,i){th.classList.remove('xasc','xdsc');if(i===sc)th.classList.add('x'+sortDir);});
  var tb=g('_xptb');if(!tb)return;
  tb.innerHTML=data.map(function(s2){var idle=s2.lastStow>0?Date.now()-s2.lastStow:0,ic=s2.status==='INACTIVE'&&idle>300000?'xid':'';return'<tr data-login="'+s2.login+'"><td><div class="xac"><img src="https://internal-cdn.amazon.com/badgephotos.amazon.com/?login='+s2.login+'" onerror="this.style.display=\'none\'"><span class="'+ic+'">'+s2.name+'</span></div></td><td>'+s2.login+'</td><td>'+s2.location+'</td><td>'+s2.uph+'</td><td>'+s2.totalStowed.toLocaleString()+'</td><td>'+(s2.lastStow>0?new Date(s2.lastStow).toLocaleTimeString('en-IE',{hour12:false}):'--:--')+'</td><td data-action="idle" style="cursor:pointer;text-decoration:underline;color:var(--pri);">'+fmt(idle)+'</td><td>'+s2.shift+'</td></tr>';}).join('');
  // ✅ Attach click events to table rows
  tb.querySelectorAll('tr').forEach(function(row){
    row.addEventListener('click', function(e){
      if(e.target.dataset.action==='idle'){e.stopPropagation();si(row.dataset.login);return;}
      sas2(row.dataset.login);
    });
  });
}

function st(col){renderTable(col,sc===col&&sortDir==='desc'?'asc':'desc');}
function af(){renderTable();}
function popAF(){
  var cl=g('_xcf')?g('_xcf').value:'ALL',sel=g('_xaf');if(!sel)return;var cur=sel.value;
  sel.innerHTML='<option value="ALL">All</option>';
  var aisles=[...new Set(stowers.filter(function(s2){return cl==='ALL'||s2.cluster===cl;}).map(function(s2){return s2.location;}).filter(Boolean))].sort();
  aisles.forEach(function(a){if(a!=='N/A'){var o=document.createElement('option');o.value=a;o.textContent=a;sel.appendChild(o);}});
  if(aisles.indexOf(cur)>-1)sel.value=cur;
}
function sas2(login){var s2=stowers.find(function(x){return x.login===login;});if(!s2)return;var e=g('_xadmt');if(e)e.textContent=s2.name;var idle=s2.lastStow>0?Date.now()-s2.lastStow:0;var b=g('_xadmb');if(b)b.innerHTML='<div style="text-align:center;margin-bottom:10px;"><img src="https://internal-cdn.amazon.com/badgephotos.amazon.com/?login='+s2.login+'" onerror="this.style.display=\'none\'" style="width:68px;height:68px;border-radius:50%;object-fit:cover;border:3px solid var(--bdr);"><div style="font-size:.82rem;color:#6c757d;margin-top:3px;">'+s2.login+'</div></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:6px 14px;background:var(--bg);padding:12px;border-radius:7px;"><div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bdr);font-size:.82rem;"><span>UPH</span><strong>'+s2.uph+'</strong></div><div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bdr);font-size:.82rem;"><span>Total Stowed</span><strong>'+s2.totalStowed.toLocaleString()+'</strong></div><div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bdr);font-size:.82rem;"><span>Location</span><strong>'+s2.location+'</strong></div><div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bdr);font-size:.82rem;"><span>Shift</span><strong>'+s2.shift+'</strong></div><div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bdr);font-size:.82rem;"><span>Last Stow</span><strong>'+(s2.lastStow>0?new Date(s2.lastStow).toLocaleTimeString('en-IE',{hour12:false}):'--:--')+'</strong></div><div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bdr);font-size:.82rem;"><span>Live Idle</span><strong>'+fmt(idle)+'</strong></div><div style="display:flex;justify-content:space-between;padding:5px 0;font-size:.82rem;"><span>Status</span><strong>'+s2.status+'</strong></div><div style="display:flex;justify-content:space-between;padding:5px 0;font-size:.82rem;"><span>Target UPH</span><strong>'+s2.target+'</strong></div></div>';om('_xadm');}
function sad(pair){var e=g('_xadm2t');if(e)e.textContent='Associates in '+pair;var a1=pair.split('-')[0],a2=pair.split('-')[1];var as=stowers.filter(function(s2){return s2.location===a1||s2.location===a2;});var b=g('_xadm2b');if(!b)return;b.innerHTML=as.length===0?'<p style="text-align:center;padding:16px;color:#6c757d;">No associates in this aisle.</p>':'<table style="width:100%;border-collapse:collapse;font-size:.82rem;"><thead><tr><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Associate</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Loc</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">UPH</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Stowed</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Idle</th></tr></thead><tbody>'+as.map(function(s2){var idle=s2.lastStow>0?Date.now()-s2.lastStow:0;return'<tr style="cursor:pointer;" data-login2="'+s2.login+'"><td style="padding:6px 7px;border-bottom:1px solid var(--bdr);"><div class="xac"><img src="https://internal-cdn.amazon.com/badgephotos.amazon.com/?login='+s2.login+'" onerror="this.style.display=\'none\'"><span>'+s2.name+'</span></div></td><td style="padding:6px;border-bottom:1px solid var(--bdr);text-align:center;">'+s2.location+'</td><td style="padding:6px;border-bottom:1px solid var(--bdr);text-align:center;">'+s2.uph+'</td><td style="padding:6px;border-bottom:1px solid var(--bdr);text-align:center;">'+s2.totalStowed.toLocaleString()+'</td><td style="padding:6px;border-bottom:1px solid var(--bdr);text-align:center;">'+fmt(idle)+'</td></tr>';}).join('')+'</tbody></table>';
  // Attach clicks
