.xpst strong{display:block;font-size:.88rem;font-weight:700;color:var(--hdr)}
.xpst span{font-size:.65rem;color:#6c757d;text-transform:uppercase}
#_xasb{width:100%;padding:12px;background:var(--card);border:2px solid var(--bdr);border-radius:7px;font-size:.88rem;font-weight:600;cursor:pointer;display:flex;justify-content:center;align-items:center;gap:8px;color:var(--hdr)}
#_xasb .xbg{background:var(--err);color:#fff;border-radius:50%;width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;font-size:.78rem}
.xfb2{display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:9px;padding-bottom:9px;border-bottom:1px solid var(--bdr)}
.xfb2 label{font-size:.78rem;font-weight:500}
.xfb2 select,.xfb2 input[type=number]{padding:3px 6px;border:1px solid var(--bdr);border-radius:4px;font-size:.78rem}
.xtog{display:flex;align-items:center;gap:5px;margin-left:auto;font-size:.78rem}
.xsw{position:relative;display:inline-block;width:36px;height:19px}
.xsw input{opacity:0;width:0;height:0}
.xsl{position:absolute;cursor:pointer;inset:0;background:#ccc;border-radius:19px;transition:.3s}
.xsl:before{position:absolute;content:"";height:13px;width:13px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.3s}
input:checked+.xsl{background:var(--ok)}
input:checked+.xsl:before{transform:translateX(17px)}
.xmov{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:2147483648;display:none;align-items:center;justify-content:center}
.xmov.show{display:flex}
.xmob{background:var(--card);border-radius:10px;box-shadow:0 10px 30px rgba(0,0,0,.2);display:flex;flex-direction:column;width:88%;max-width:860px;max-height:88vh;overflow:hidden}
.xmoh{padding:10px 16px;border-bottom:1px solid var(--bdr);display:flex;justify-content:space-between;align-items:center;background:var(--card);flex-shrink:0}
.xmoh h2{font-size:.9rem;color:var(--hdr);margin:0}
.xmoc{font-size:1.4rem;font-weight:700;cursor:pointer;border:none;background:none;color:#888;line-height:1}
.xmbd{padding:14px;overflow-y:auto;flex-grow:1}
.xfcg{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px}
.xfc{background:var(--bg);border-radius:7px;padding:10px}
.xfch{display:flex;align-items:center;gap:7px;margin-bottom:7px;padding-bottom:7px;border-bottom:1px solid var(--bdr)}
.xfch img{width:34px;height:34px;border-radius:50%;object-fit:cover}
.xfcb{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;text-align:center}
.xfs span{font-size:.68rem;color:#6c757d;display:block}
.xfs strong{font-size:.9rem;color:var(--hdr)}
.xfs strong.xe{color:var(--err)}
#_xnc{position:fixed;bottom:14px;right:14px;z-index:2147483649;display:flex;flex-direction:column-reverse;gap:6px}
.xno{width:280px;background:var(--card);border-radius:7px;box-shadow:0 5px 15px rgba(0,0,0,.2);display:flex;align-items:center;padding:10px;gap:8px;cursor:pointer;position:relative}
.xno.xnf{border-left:5px solid var(--err)}.xno.xna{border-left:5px solid var(--warn)}.xno.xnd{border-left:5px solid #d63384}
.xnc strong{display:block;font-size:.84rem;color:var(--hdr)}
.xnc p{font-size:.76rem;margin-top:2px}
.xnx{position:absolute;top:3px;right:5px;font-size:1rem;cursor:pointer;border:none;background:none;color:#aaa}
#_xt{display:none;position:fixed;top:55px;left:50%;transform:translateX(-50%);background:#333;color:#fff;padding:7px 14px;border-radius:6px;z-index:2147483650;font-size:.84rem}
.xdbs{display:flex;justify-content:space-around;background:#f8f9fa;border:1px solid var(--bdr);border-radius:7px;padding:10px;margin-bottom:10px}
.xdbi .xl{font-size:.65rem;color:#6c757d;font-weight:600;text-transform:uppercase}
.xdbi .xv{font-size:1.4rem;font-weight:800;color:var(--hdr)}`;

var el=document.createElement('style');el.textContent=CSS;document.head.appendChild(el);
// ── HTML ─────────────────────────────────────────────────────────────────────
var H=`<div id="_xt"></div><div id="_xnc"></div>
