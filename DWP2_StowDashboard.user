<div class="xmb"><div class="xl">Pending Stow</div><div class="xv" id="_xpps">--</div><ul><li><span>Inducted</span><span id="_xpi2">--</span></li><li><span>Buffered</span><span id="_xpb">--</span></li><li><span>PS</span><span id="_xpps2">--</span></li></ul></div>
<div class="xmb"><div class="xl">Stowed</div><div class="xv" id="_xpst">--</div></div></div></div>
<div class="xc xfw"><h2>Live Aisle Status</h2>
