  om('_xadm2');
}
function updateIdle(sw){var now=Date.now();sw.forEach(function(s2){var t=idleT[s2.login],last=s2.lastStow||0;if(!t){idleT[s2.login]={intervals:[],lastScan:last,idleSince:null};return;}if(last>t.lastScan){if(t.idleSince!==null){var iv={start:t.idleSince,end:last};if(iv.end-iv.start>30000)t.intervals.push(iv);t.idleSince=null;}}var li=last>0?now-last:0;if(t.idleSince===null&&li>35000)t.idleSince=last;t.lastScan=last;});}
function si(login){var s2=stowers.find(function(x){return x.login===login;}),t=idleT[login];var e=g('_xidmt');if(e)e.textContent='Idle - '+(s2?s2.name:login);if(!t||(t.intervals.length===0&&t.idleSince===null)){var b=g('_xidmb');if(b)b.innerHTML='<p style="text-align:center;padding:16px;">No significant idle time recorded.</p>';om('_xidm');return;}var total=t.intervals.reduce(function(sum,i){return sum+(i.end-i.start);},0);if(t.idleSince!==null)total+=Date.now()-t.idleSince;var list=t.intervals.map(function(i){return{start:i.start,end:i.end,live:false};});if(t.idleSince!==null)list.push({start:t.idleSince,end:Date.now(),live:true});list.sort(function(a,b){return b.start-a.start;});var b=g('_xidmb');if(b)b.innerHTML='<h3 style="text-align:center;margin-bottom:10px;font-size:1rem;color:var(--hdr);">Total Idle: '+fmt(total)+'</h3><ul style="list-style:none;border:1px solid var(--bdr);border-radius:6px;max-height:36vh;overflow-y:auto;">'+list.map(function(i){return'<li style="display:flex;justify-content:space-between;padding:7px 11px;border-bottom:1px solid var(--bdr);font-size:.82rem;"><span>'+new Date(i.start).toLocaleTimeString('en-IE',{hour:'2-digit',minute:'2-digit'})+' - '+(i.live?'Present':new Date(i.end).toLocaleTimeString('en-IE',{hour:'2-digit',minute:'2-digit'}))+'</span><strong>'+fmt(i.end-i.start)+(i.live?' (Live)':'')+'</strong></li>';}).join('')+'</ul>';om('_xidm');}
function sf(){var b=g('_xfmb');if(!b)return;var faList=stowers.filter(function(s2){return s2.fsaf>0;}).sort(function(a,b2){return b2.fsaf-a.fsaf;});b.innerHTML=faList.length===0?'<p style="text-align:center;padding:16px;font-size:.9rem;">No FSAF errors. ✅</p>':faList.map(function(a){return'<div class="xfc"><div class="xfch"><img src="https://internal-cdn.amazon.com/badgephotos.amazon.com/?login='+a.login+'" onerror="this.style.display=\'none\'"><div><div style="font-weight:600;font-size:.86rem;color:var(--hdr);">'+a.name+'</div><div style="font-size:.75rem;color:#6c757d;">'+a.login+'</div></div></div><div class="xfcb"><div class="xfs"><span>Location</span><strong>'+a.location+'</strong></div><div class="xfs"><span>FSAF</span><strong class="xe">'+a.fsaf+'</strong></div><div class="xfs"><span>DPMO</span><strong>'+a.fsafDpmo+'</strong></div></div></div>';}).join('');om('_xfm');}
function checkFsaf(sw){if(Object.keys(prevFsaf).length===0){sw.forEach(function(s2){prevFsaf[s2.login]=s2.fsaf;});return;}sw.forEach(function(s2){if(prevFsaf[s2.login]!==undefined&&s2.fsaf>prevFsaf[s2.login])notif('xnf',s2.login,'New FSAF: '+s2.name,'Location: <strong>'+s2.location+'</strong> | Total: <strong>'+s2.fsaf+'</strong>',function(){sas2(s2.login);});});prevFsaf={};sw.forEach(function(s2){prevFsaf[s2.login]=s2.fsaf;});}
function sas(){var b=g('_xamb');if(!b)return;var tR=parseInt(g('_xtr')?g('_xtr').value:61)||61;var rc=document.querySelectorAll('.xcr');if(rc.length===0){b.innerHTML='<p style="text-align:center;padding:16px;">No aisles need support. ✅</p>';om('_xam');return;}var seen=new Set();b.innerHTML='';rc.forEach(function(cell){var row=cell.closest('tr');if(!row)return;var pair=row.querySelector('td')&&row.querySelector('td').textContent;if(!pair||seen.has(pair))return;seen.add(pair);var a1=pair.split('-')[0],a2=pair.split('-')[1];var as=stowers.filter(function(s2){return s2.location===a1||s2.location===a2;});var card=document.createElement('div');card.style='background:var(--bg);border-radius:7px;padding:10px;';card.innerHTML='<h4 style="display:flex;justify-content:space-between;margin-bottom:8px;padding-bottom:7px;border-bottom:1px solid var(--bdr);color:var(--hdr);font-size:.84rem;">'+pair+'<span style="color:var(--err);font-size:.78rem;">Buffer: '+cell.textContent+'</span></h4>'+(as.length>0?as.map(function(s2){return'<div style="display:flex;align-items:center;gap:7px;margin-bottom:5px;"><img src="https://internal-cdn.amazon.com/badgephotos.amazon.com/?login='+s2.login+'" onerror="this.style.display=\'none\'" style="width:26px;height:26px;border-radius:50%;"><span style="font-weight:500;font-size:.82rem;">'+s2.name+'</span></div>';}).join(''):'<em style="color:#6c757d;font-size:.78rem;">No stower in this aisle.</em>');b.appendChild(card);});om('_xam');}
function fpa(pair){var a1=pair.split('-')[0],a2=pair.split('-')[1];var e=g('_xpmt');if(e)e.textContent='Packages in '+pair;var b=g('_xpmb');if(b)b.innerHTML='<p style="text-align:center;padding:16px;">Loading...</p>';om('_xpm2');var rb={nodeId:station,packageStatusMap:{'Pending Stow':[]},filters:[{__type:'TermFilter:http://internal.amazon.com/coral/com.amazon.oculusservice.model.filter/',filterMap:{AISLE:[a1,a2]}}]};var c=cyc();if(c!=='ALL')rb.filters[0].filterMap.CYCLE=[c];api('/os/getDrillDownData','oculus',rb,function(err,data){pkgC[pair]=(!err&&data)?data.packageResultList||[]:[];rpkg(pair,'Packages in '+pair);});}
function rpkg(key,title){var pkgs=pkgC[key]||[];var e=g('_xpmt');if(e)e.textContent=title;var b=g('_xpmb');if(!b)return;if(pkgs.length===0){b.innerHTML='<p style="text-align:center;padding:16px;">No packages found.</p>';return;}b.innerHTML='<div style="margin-bottom:7px;display:flex;justify-content:space-between;align-items:center;"><strong style="font-size:.84rem;">Total: '+pkgs.length+'</strong><button id="_btn_dlp_'+key+'" style="padding:3px 9px;border-radius:4px;border:none;background:var(--pri);color:#fff;cursor:pointer;font-size:.76rem;">Download CSV</button></div><div style="max-height:50vh;overflow-y:auto;"><table style="width:100%;border-collapse:collapse;font-size:.8rem;"><thead><tr><th style="padding:6px;background:#f8f9fa;border-bottom:2px solid var(--bdr);text-align:left;">Tracking ID</th><th style="padding:6px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Aisle</th><th style="padding:6px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Sort Zone</th></tr></thead><tbody>'+pkgs.map(function(p){return'<tr><td style="padding:5px 6px;border-bottom:1px solid var(--bdr);">'+(p.trackingId||'N/A')+'</td><td style="padding:5px 6px;border-bottom:1px solid var(--bdr);text-align:center;">'+(p.aisle||'N/A')+'</td><td style="padding:5px 6px;border-bottom:1px solid var(--bdr);text-align:center;">'+(p.sortZone||'N/A')+'</td></tr>';}).join('')+'</tbody></table></div>';var btn=g('_btn_dlp_'+key);if(btn)btn.addEventListener('click',function(){dlp(key);});}
function dlp(key){var pkgs=pkgC[key]||[];if(!pkgs.length)return;var csv='TrackingID,Aisle,SortZone\n';pkgs.forEach(function(p){csv+='"'+(p.trackingId||'')+'","'+(p.aisle||'')+'","'+(p.sortZone||'')+'"\n';});var a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download='packages_'+station+'_'+key+'_'+new Date().toISOString().slice(0,10)+'.csv';a.click();}
function sa(){om('_xagm');var b=g('_xagmb');if(b)b.innerHTML='<p style="text-align:center;padding:16px;">Analyzing...</p>';var rb={nodeId:station,size:5000,packageStatusMap:{'Inducted':[],'Stow Problem Solve':[],'Stow Buffered':[]},filters:[{__type:'TermFilter:http://internal.amazon.com/coral/com.amazon.oculusservice.model.filter/',filterMap:{SHIPMENT_TYPE:['Delivery']}},{__type:'RangeFilter:http://internal.amazon.com/coral/com.amazon.oculusservice.model.filter/',filterMap:{}}]};var c=cyc();if(c!=='ALL')rb.filters[0].filterMap.CYCLE=[c];api('/os/getDrillDownData','oculus',rb,function(err,data){var pkgs=(!err&&data)?data.packageResultList||[]:[];if(pkgs.length===0){var b2=g('_xagmb');if(b2)b2.innerHTML='<p style="text-align:center;padding:16px;">No pending packages. ✅</p>';return;}var groups={},keys=[];var unk=0;pkgs.forEach(function(pkg){if(!pkg.lastUpdatedTime){unk++;return;}var d=new Date(pkg.lastUpdatedTime.replace(' ','T'));if(isNaN(d.getTime())){unk++;return;}d.setMinutes(0,0,0);var k=d.getTime();var h=d.getHours();if(!groups[k]){groups[k]={label:(h<10?'0':'')+h+':00 - '+(h<10?'0':'')+h+':59',count:0,date:d,packages:[]};keys.push(k);}groups[k].count++;groups[k].packages.push(pkg);});keys.sort(function(a,b2){return a-b2;});var now=new Date().getHours();var html='<div style="text-align:center;margin-bottom:9px;"><strong style="font-size:.9rem;">Total Pending: '+pkgs.length+'</strong><div style="font-size:.72rem;color:#999;">Click a row to see Tracking IDs</div></div><table style="width:100%;border-collapse:collapse;font-size:.82rem;"><thead><tr><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Hour</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Count</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">%</th></tr></thead><tbody>';keys.forEach(function(k){var gr=groups[k],pct=((gr.count/pkgs.length)*100).toFixed(1),gh=gr.date.getHours();var bg='';if(now-gh>=3)bg='background:#ffe8cc;';else if(gh<now)bg='background:#fff3cd;';html+='<tr style="'+bg+'cursor:pointer;" data-agkey="'+k+'"><td style="padding:7px;border-bottom:1px solid var(--bdr);font-weight:600;">'+gr.label+'</td><td style="padding:7px;border-bottom:1px solid var(--bdr);text-align:center;font-weight:700;">'+gr.count+'</td><td style="padding:7px;border-bottom:1px solid var(--bdr);text-align:center;">'+pct+'%</td></tr>';});if(unk>0)html+='<tr style="background:#f8d7da;"><td style="padding:7px;">Unknown</td><td style="padding:7px;text-align:center;">'+unk+'</td><td style="padding:7px;text-align:center;">-</td></tr>';html+='</tbody></table>';var b2=g('_xagmb');if(b2){b2.innerHTML=html;b2.querySelectorAll('tr[data-agkey]').forEach(function(row){row.addEventListener('click',function(){sap(parseInt(row.dataset.agkey));});});}window._xag=groups;});}
function sap(key){var gr=window._xag&&window._xag[key];if(!gr)return;var ck='aging-'+key;pkgC[ck]=gr.packages;var e=g('_xpmt');if(e)e.textContent='Inducted: '+gr.label;var b=g('_xpmb');if(b)b.innerHTML='<p style="text-align:center;padding:16px;">Loading...</p>';om('_xpm2');rpkg(ck,'Inducted: '+gr.label);}
function ss(){var top=stowers.filter(function(p){return!removed.has(p.login);}).sort(function(a,b){return b.totalStowed-a.totalStowed||b.uph-a.uph;}).slice(0,10);var e=g('_xssg');if(!e)return;e.innerHTML=top.map(function(p,i){var bc=i===0?'#e5a700':i===1?'#a9b4c2':i===2?'#b87333':'var(--pri)';return'<div style="background:var(--card);border-radius:8px;padding:10px;box-shadow:var(--sh);display:flex;flex-direction:column;align-items:center;border-left:5px solid '+bc+';position:relative;"><button data-rmlogin="'+p.login+'" style="position:absolute;top:2px;right:4px;background:#e53e3e;color:#fff;border:none;border-radius:50%;width:18px;height:18px;font-size:11px;cursor:pointer;opacity:.2;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.2">×</button><div style="font-size:.85rem;font-weight:800;color:var(--hdr);">#'+(i+1)+'</div><img src="https://internal-cdn.amazon.com/badgephotos.amazon.com/?login='+p.login+'" onerror="this.onerror=null;this.src=\'https://placehold.co/100x100/eef1f5/3d4852?text=?\'" style="width:42px;height:42px;border-radius:50%;object-fit:cover;margin:4px 0;"><div style="font-weight:600;font-size:.8rem;text-align:center;color:var(--hdr);">'+p.name+'</div><div style="display:flex;justify-content:space-around;width:100%;border-top:1px solid var(--bdr);padding-top:6px;margin-top:6px;"><div style="text-align:center;"><span style="font-size:.62rem;color:#6c757d;display:block;">Stowed</span><strong style="font-size:.88rem;font-weight:700;color:var(--hdr);">'+p.totalStowed.toLocaleString()+'</strong></div><div style="text-align:center;"><span style="font-size:.62rem;color:#6c757d;display:block;">UPH</span><strong style="font-size:.88rem;font-weight:700;color:var(--hdr);">'+p.uph+'</strong></div></div></div>';}).join('');
  // Attach remove buttons
  e.querySelectorAll('button[data-rmlogin]').forEach(function(btn){btn.addEventListener('click',function(ev){ev.stopPropagation();rm(btn.dataset.rmlogin);});});
  om('_xssm');
}
function rm(login){removed.add(login);localStorage.setItem('_xrm',JSON.stringify([...removed]));ss();renderTop();}
function rr(){removed.clear();localStorage.removeItem('_xrm');ss();renderTop();toast('🔄 Reset done');}
// ✅ FIX: renamed function from sd() to showDb() to avoid collision with sortDir variable
function showDb(){om('_xdbm');dbC={};if(!cycleId){var e=g('_xdbc2');if(e)e.innerHTML='<div style="text-align:center;padding:24px;"><h2 style="color:#ff9900;">⚠️ Authorization Needed</h2><p style="margin-top:7px;">Navigate to the <strong>Stow Breakdown</strong> tab on the SCC first, then click Double Binning again.</p></div>';return;}var e2=g('_xdbcl');if(e2)e2.textContent='Cycle ID: ...'+cycleId.substring(0,8);ld('A');}
function ld(cl){if(dbC[cl]){rdb(cl,dbC[cl]);return;}var e=g('_xdbc2');if(e)e.innerHTML='<p style="text-align:center;padding:20px;color:#666;">Loading Cluster '+cl+'...</p>';var c=cyc();var rb={groupBy:'AISLE',filters:{NODE:[station],CLUSTER:[cl],CYCLE:[c],CYCLE_ID:[cycleId]},metrics:['USED_BAG_COUNT','PLANNED_BAG_COUNT']};api('svs/bags/metrics','stow',rb,function(err,data){dbC[cl]=(!err&&data)?data.groupedBagMetrics||{}:{};rdb(cl,dbC[cl]);});}
function rdb(cl,data){var keys=Object.keys(data).sort(function(a,b){return parseInt(a.replace(/\D/g,''))-parseInt(b.replace(/\D/g,''));});var e=g('_xdbc2');if(!e)return;if(keys.length===0){e.innerHTML='<p style="text-align:center;padding:20px;">No bag data for Cluster '+cl+'.</p>';return;}var tp=0,tu=0;keys.forEach(function(k){tp+=data[k].plannedBagCount||0;tu+=data[k].usedBagCount||0;});var diff=tu-tp,dc2=diff>0?'#d63384':diff===0?'var(--ok)':'#6c757d';e.innerHTML='<div class="xdbs"><div class="xdbi"><div class="xl">Planned</div><div class="xv">'+tp+'</div></div><div class="xdbi"><div class="xl">Used</div><div class="xv">'+tu+'</div></div><div class="xdbi"><div class="xl">Difference</div><div class="xv" style="color:'+dc2+';">'+(diff>0?'+':'')+diff+'</div></div></div><table style="width:100%;border-collapse:collapse;font-size:.82rem;"><thead><tr><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);text-align:left;">Aisle</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);text-align:center;">Used</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);text-align:center;">Planned</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);text-align:center;">Diff</th><th style="padding:7px;background:#f8f9fa;border-bottom:2px solid var(--bdr);text-align:center;">Status</th></tr></thead><tbody>'+keys.map(function(k){var p=data[k].plannedBagCount||0,u=data[k].usedBagCount||0,d=u-p;var st2=u>p?'background:#f8d7da;color:#842029;font-weight:bold;':u===p&&p>0?'background:#d1e7dd;color:#0f5132;':'';var status=u>p?'⚠️ OVER':u===p&&p>0?'FULL':'OK';return'<tr style="'+st2+'"><td style="padding:6px 8px;border-bottom:1px solid var(--bdr);font-weight:600;">'+k+'</td><td style="padding:6px;border-bottom:1px solid var(--bdr);text-align:center;">'+u+'</td><td style="padding:6px;border-bottom:1px solid var(--bdr);text-align:center;">'+p+'</td><td style="padding:6px;border-bottom:1px solid var(--bdr);text-align:center;">'+(d>0?'+':'')+d+'</td><td style="padding:6px;border-bottom:1px solid var(--bdr);text-align:center;">'+status+'</td></tr>';}).join('')+'</tbody></table>';}
function checkDb(){if(!cycleId)return;var c=cyc();if(!c||c==='ALL')return;var cls=['A','B','C','D','E','F','G'],done=0,ex=0,ai=0;cls.forEach(function(cl){var rb={groupBy:'AISLE',filters:{NODE:[station],CLUSTER:[cl],CYCLE:[c],CYCLE_ID:[cycleId]},metrics:['USED_BAG_COUNT','PLANNED_BAG_COUNT']};api('svs/bags/metrics','stow',rb,function(err,data){if(!err&&data){Object.keys(data.groupedBagMetrics||{}).forEach(function(k){var p=data.groupedBagMetrics[k].plannedBagCount||0,u=data.groupedBagMetrics[k].usedBagCount||0;if(u>p){ex+=u-p;ai++;}});}if(++done===cls.length){var b=g('_xdbb');if(b){if(ex>0){b.textContent=ex;b.style.display='inline-block';}else b.style.display='none';}if(ex>lastDb)notif('xnd',null,'Double Binning Alert','<strong>'+ex+'</strong> extra bags across <strong>'+ai+'</strong> aisles.',function(){showDb();});lastDb=ex;}});});}
function showPending(){om('_xpdm');fp();}
function fp(){var b=g('_xpdb');if(b)b.innerHTML='<p style="text-align:center;padding:16px;">Loading...</p>';var c=g('_xpdcf')?g('_xpdcf').value:'ALL';var now=new Date();var start=new Date(now.getFullYear(),now.getMonth(),now.getDate(),4,0,0);if(now.getHours()<4)start.setDate(start.getDate()-1);var end=new Date(start);end.setDate(end.getDate()+1);var rb={nodeId:station,packageStatusMap:{'Inducted':[],'Stow Problem Solve':[],'Stow Buffered':[]},filters:[{__type:'TermFilter:http://internal.amazon.com/coral/com.amazon.oculusservice.model.filter/',filterMap:{SHIPMENT_TYPE:['Delivery']}},{__type:'RangeFilter:http://internal.amazon.com/coral/com.amazon.oculusservice.model.filter/',filterMap:{}}],lastUpdatedRange:{startTime:Math.floor(start.getTime()/1000),endTime:Math.floor(end.getTime()/1000)}};if(c!=='ALL')rb.filters[0].filterMap.CYCLE=[c];var key='pending-'+c;api('/os/getDrillDownData','oculus',rb,function(err,data){var pkgs=(!err&&data)?data.packageResultList||[]:[];pkgC[key]=pkgs;var b2=g('_xpdb');if(!b2)return;if(pkgs.length===0){b2.innerHTML='<p style="text-align:center;padding:16px;">No pending packages. ✅</p>';return;}b2.innerHTML='<div style="margin-bottom:7px;display:flex;justify-content:space-between;align-items:center;"><strong style="font-size:.84rem;">Total: '+pkgs.length+'</strong><button id="_btn_dlp_pend" style="padding:3px 9px;border-radius:4px;border:none;background:var(--pri);color:#fff;cursor:pointer;font-size:.76rem;">Download CSV</button></div><div style="max-height:50vh;overflow-y:auto;"><table style="width:100%;border-collapse:collapse;font-size:.8rem;"><thead><tr><th style="padding:6px;background:#f8f9fa;border-bottom:2px solid var(--bdr);text-align:left;">Tracking ID</th><th style="padding:6px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Aisle</th><th style="padding:6px;background:#f8f9fa;border-bottom:2px solid var(--bdr);">Sort Zone</th></tr></thead><tbody>'+pkgs.map(function(p){return'<tr><td style="padding:5px 6px;border-bottom:1px solid var(--bdr);">'+(p.trackingId||'N/A')+'</td><td style="padding:5px 6px;border-bottom:1px solid var(--bdr);text-align:center;">'+(p.aisle||'N/A')+'</td><td style="padding:5px 6px;border-bottom:1px solid var(--bdr);text-align:center;">'+(p.sortZone||'N/A')+'</td></tr>';}).join('')+'</tbody></table></div>';var dlBtn=g('_btn_dlp_pend');if(dlBtn)dlBtn.addEventListener('click',function(){dlp(key);});});}
function notif(type,login,title,body,onClick){var c=g('_xnc');if(!c)return;var n=document.createElement('div');n.className='xno '+type;n.innerHTML=(login?'<img src="https://internal-cdn.amazon.com/badgephotos.amazon.com/?login='+login+'" onerror="this.style.display=\'none\'" style="width:32px;height:32px;border-radius:50%;flex-shrink:0;">':'')+'<div class="xnc"><strong>'+title+'</strong><p>'+body+'</p></div><button class="xnx">×</button>';n.querySelector('.xnx').addEventListener('click',function(ev){ev.stopPropagation();n.remove();});n.addEventListener('click',function(){if(onClick)onClick();n.remove();});c.appendChild(n);setTimeout(function(){if(n.parentNode)n.remove();},10000);}
function dc(){var csv='Associate,Login,Location,UPH,Total Stowed,Last Stow,Live Idle,Shift\n';stowers.forEach(function(s2){var idle=s2.lastStow>0?Date.now()-s2.lastStow:0;csv+='"'+s2.name+'","'+s2.login+'","'+s2.location+'","'+s2.uph+'","'+s2.totalStowed+'","'+(s2.lastStow>0?new Date(s2.lastStow).toLocaleTimeString('en-IE',{hour12:false}):'--:--')+'","'+fmt(idle)+'","'+s2.shift+'"\n';});var a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));a.download='stow_'+station+'_'+new Date().toISOString().slice(0,10)+'.csv';a.click();toast('✅ CSV Downloaded');}
function sv(){localStorage.setItem('_xset',JSON.stringify({target:g('_xtgt')?g('_xtgt').value:365,tG:g('_xtg')?g('_xtg').value:1,tY:g('_xty')?g('_xty').value:21,tO:g('_xto')?g('_xto').value:41,tR:g('_xtr')?g('_xtr').value:61,cycle:cyc()}));toast('✅ Settings Saved');fa();}
function loadSettings(){
  var s2=JSON.parse(localStorage.getItem('_xset')||'{}');
  if(s2.target&&g('_xtgt'))g('_xtgt').value=s2.target;
  if(s2.tG&&g('_xtg'))g('_xtg').value=s2.tG;
  if(s2.tY&&g('_xty'))g('_xty').value=s2.tY;
  if(s2.tO&&g('_xto'))g('_xto').value=s2.tO;
  if(s2.tR&&g('_xtr'))g('_xtr').value=s2.tR;
  if(s2.cycle&&g('_xcy'))g('_xcy').value=s2.cycle;
  else if(g('_xcy'))g('_xcy').value='CYCLE_1';
  if(!s2.target&&g('_xtgt'))g('_xtgt').value='365';
}
function tp(){paused=!paused;var b=g('_xpb');if(b)b.textContent=paused?'▶':'⏸';if(!paused)fa();}
function ps(){var c=prompt('Enter Station Code (e.g. DWP2):',station||'');if(c&&c.trim().length>=3){station=c.trim().toUpperCase();localStorage.setItem('stowStation',station);var b=g('_xstb');if(b)b.textContent=station+' ▾';fa();}}

// ── BIND ALL EVENTS (no inline onclick!) ─────────────────────────────────────
// ✅ FIX: Using addEventListener instead of inline onclick for reliability
g('_xstb').addEventListener('click', ps);
g('_btn_save').addEventListener('click', sv);
g('_btn_fsaf').addEventListener('click', sf);
g('_btn_aging').addEventListener('click', sa);
g('_btn_db').addEventListener('click', showDb);
g('_btn_pending').addEventListener('click', showPending);
g('_btn_csv').addEventListener('click', dc);
g('_btn_refresh').addEventListener('click', fa);
g('_xpb').addEventListener('click', tp);
g('_scl').addEventListener('click', function(){g('_sd').style.display='none';});
g('_btn_apply').addEventListener('click', fa);
g('_btn_screenshot').addEventListener('click', ss);
g('_btn_reset_removed').addEventListener('click', rr);
g('_xasb').addEventListener('click', sas);
g('_xcf').addEventListener('change', af);
g('_xaf').addEventListener('change', af);
g('_xao').addEventListener('change', af);
g('_xcy').addEventListener('change', fa);
g('_xdbc').addEventListener('change', function(){ld(this.value);});
g('_xpdcf').addEventListener('change', fp);

// Close modals on backdrop click
document.querySelectorAll('.xmov').forEach(function(m){m.addEventListener('click',function(e){if(e.target===m)m.classList.remove('show');});});
// Close modal buttons
g('_cl_xfm').addEventListener('click', function(){cm('_xfm');});
g('_cl_xam').addEventListener('click', function(){cm('_xam');});
g('_cl_xadm').addEventListener('click', function(){cm('_xadm');});
g('_cl_xpm2').addEventListener('click', function(){cm('_xpm2');});
g('_cl_xadm2').addEventListener('click', function(){cm('_xadm2');});
g('_cl_xidm').addEventListener('click', function(){cm('_xidm');});
g('_cl_xagm').addEventListener('click', function(){cm('_xagm');});
g('_cl_xssm').addEventListener('click', function(){cm('_xssm');});
g('_cl_xdbm').addEventListener('click', function(){cm('_xdbm');});
g('_cl_xpdm').addEventListener('click', function(){cm('_xpdm');});

// Table header sort
document.querySelectorAll('#_xpt thead th').forEach(function(th){
  th.addEventListener('click', function(){st(parseInt(th.dataset.col));});
});

// ── INIT (single call, no duplicates) ────────────────────────────────────────
loadSettings();
var stb=g('_xstb');if(stb)stb.textContent=station+' ▾';
startTimer();
fa();

} // end initDashboard

// Wait for page to be ready then add bubble
function waitAndInit() {
  if (document.body) {
    addBubble();
  } else {
    setTimeout(waitAndInit, 500);
  }
}

waitAndInit();

})();
