// ==UserScript==
// @name         DWP2 Stow Performance Dashboard
// @namespace    https://phonetool.amazon.com/users/haoulati
// @version      1.1
// @description  Stow Performance Dashboard - injecte un dashboard complet sur le SCC
// @author       haoulati@
// @match        https://logistics.amazon.co.uk/station/dashboard/*
// @match        https://logistics.amazon.com/station/dashboard/*
// @updateURL    https://raw.githubusercontent.com/haoulati/Script-DWP2/main/DWP2_StowDashboard.user.js
// @downloadURL  https://raw.githubusercontent.com/haoulati/Script-DWP2/main/DWP2_StowDashboard.user.js
// @grant        GM_xmlhttpRequest
// @grant        GM_setValue
// @grant        GM_getValue
// @run-at       document-end
// ==/UserScript==
(function() {
'use strict';

// ── Auto-detect station from SCC DOM ─────────────────────────────────────────
function detectStation() {
  try {
    var el = document.querySelector('#select2-stations-container');
    if (el && el.textContent) {
      var code = el.textContent.trim();
      if (code.length >= 3 && code.length <= 5 && /^[A-Z0-9]+$/.test(code)) return code;
    }
  } catch(e) {}
  try {
    var title = document.title;
    if (title) {
      var parts = title.split('|');
      for (var i=0; i<parts.length; i++) {
        var t = parts[i].trim();
        if (t !== 'Station Command Centre' && t.length >= 3 && t.length <= 5 && /^[A-Z0-9]+$/.test(t)) return t;
      }
    }
  } catch(e) {}
  return localStorage.getItem('stowStation') || null;
}

// ── Add bubble button to open dashboard ──────────────────────────────────────
function addBubble() {
  if (document.getElementById('_stow_bubble')) return;
  var bubble = document.createElement('button');
  bubble.id = '_stow_bubble';
  bubble.innerHTML = '&#128230;';
  bubble.title = 'Open Stow Dashboard';
  bubble.style.cssText = 'position:fixed;bottom:80px;right:20px;width:56px;height:56px;border-radius:50%;background:#1a253c;color:#fff;font-size:24px;border:none;cursor:pointer;z-index:99996;box-shadow:0 4px 12px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;';
  bubble.addEventListener('click', function() {
    var dash = document.getElementById('_sd');
    if (dash) {
      dash.style.display = dash.style.display === 'none' ? 'flex' : 'none';
    } else {
      initDashboard();
    }
  });
  document.body.appendChild(bubble);
}

function initDashboard() {
  var s = detectStation();
  if (s) localStorage.setItem('stowStation', s);

// ── CSS ──────────────────────────────────────────────────────────────────────
var CSS=`:root{--bg:#f4f6f9;--card:#fff;--text:#3d4852;--hdr:#1a253c;--bdr:#eef1f5;--sh:0 4px 12px rgba(0,0,0,.08);--pri:#4a90e2;--ok:#34c759;--warn:#ff9500;--err:#ff3b30}
#_sd{position:fixed;inset:0;z-index:2147483647;background:var(--bg);display:flex;flex-direction:column;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;color:var(--text);font-size:14px}
#_sb{background:var(--hdr);color:#fff;padding:7px 14px;display:flex;align-items:center;gap:7px;flex-wrap:wrap;flex-shrink:0;box-shadow:0 2px 8px rgba(0,0,0,.3)}
#_sb h1{font-size:.95rem;flex-shrink:0;margin:0}
#_sb select,#_sb input[type=number]{padding:3px 6px;border-radius:5px;border:none;font-size:.78rem;background:#fff;color:#333}
#_sb button{padding:3px 9px;border-radius:5px;border:none;font-weight:600;cursor:pointer;font-size:.76rem;white-space:nowrap}
.xb{background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3)!important}
.xg{background:var(--ok);color:#fff}.xp{background:var(--pri);color:#fff}.xa{background:#6f42c1;color:#fff}
.xd{background:#d63384;color:#fff}.xw{background:var(--warn);color:#fff}
#_stm{background:rgba(255,255,255,.15);border-radius:20px;padding:2px 8px;font-size:.76rem;white-space:nowrap}
#_scl{background:#ff3b30;color:#fff;border-radius:50%;width:26px;height:26px;font-size:1.1rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-left:auto;cursor:pointer;border:none}
#_sbd{flex-grow:1;overflow-y:auto;padding:14px}
#_smn{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px}
.xc{background:var(--card);border-radius:10px;box-shadow:var(--sh);padding:14px}
.xc h2{font-size:.88rem;color:var(--hdr);margin-bottom:10px;display:flex;align-items:center;gap:5px;margin-top:0}
.xfw{grid-column:1/-1}
.xmg{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:9px}
.xmb{background:var(--bg);border-radius:7px;padding:10px;border-left:4px solid var(--pri)}
.xmb .xl{font-size:.65rem;color:#6c757d;text-transform:uppercase;font-weight:600}
.xmb .xv{font-size:1.5rem;font-weight:700;color:var(--hdr);line-height:1;margin:3px 0}
.xmb ul{list-style:none;margin-top:4px}
.xmb ul li{display:flex;justify-content:space-between;font-size:.8rem;padding:2px 0;border-bottom:1px solid var(--bdr)}
.xmb ul li:last-child{border:none}
.xmb ul li span:last-child{font-weight:600}
.xfg{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:10px}
.xfb{background:var(--bg);border-radius:7px;padding:9px;border-left:4px solid #FF9900}
.xfb .xl{font-size:.65rem;color:#6c757d;text-transform:uppercase;font-weight:600}
.xfb .xv{font-size:1.4rem;font-weight:700;color:#FF9900}
.xtw{overflow-x:auto;margin-top:7px}
table{width:100%;border-collapse:collapse;font-size:.82rem}
thead th{background:#f8f9fa;color:var(--hdr);font-weight:600;padding:8px 6px;border-bottom:2px solid var(--bdr);text-align:center;cursor:pointer;user-select:none;white-space:nowrap;position:relative}
thead th::after{content:" \\2195";color:#ccc}
thead th.xasc::after{content:" \\25B2";color:#333}
thead th.xdsc::after{content:" \\25BC";color:#333}
tbody td{padding:7px 6px;border-bottom:1px solid var(--bdr);text-align:center;white-space:nowrap}
tbody tr:hover{background:#f0f4ff;cursor:pointer}
.xac{display:flex;align-items:center;gap:5px;text-align:left}
.xac img{width:26px;height:26px;border-radius:50%;object-fit:cover;background:#eee;flex-shrink:0}
.xid::before{content:"●";color:var(--err);margin-right:3px}
.xag{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px}
.xaw{border:2px solid #ccc;border-radius:7px;overflow:hidden}
.xah{background:var(--hdr);color:#fff;padding:5px 9px;font-weight:700;font-size:.85rem}
.xaw table{width:100%;border-collapse:collapse}
.xaw thead th{background:#f8f9fa;padding:4px;font-size:.75rem;border-bottom:1px solid var(--bdr);cursor:default}
.xaw thead th::after{content:""}
.xaw tbody td{padding:3px 5px;border-bottom:1px solid var(--bdr);font-size:.78rem;text-align:center}
.xaw tbody tr:hover{background:#f0f4ff;cursor:pointer}
.xan{font-weight:600;background:#f8f9fa;text-align:left!important}
.xan.xhs{background:#cfe2ff;color:#084298}
.xcg{background:#d1e7dd;color:#0f5132;font-weight:700}
.xcy{background:#fff3cd;color:#664d03;font-weight:700}
.xco{background:#ffe8cc;color:#995400;font-weight:700}
.xcr{background:#f8d7da;color:#842029;font-weight:700}
.xas{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;padding:5px;border-top:2px solid #ccc;background:#fafafa}
.xab{text-align:center;padding:4px;border-radius:4px;background:#eef1f5}
.xab .xl{font-size:.6rem;color:#6c757d;font-weight:600;text-transform:uppercase}
.xab .xv{font-size:1rem;font-weight:700;color:var(--hdr)}
.xpl{list-style:none;max-height:300px;overflow-y:auto}
.xpi{display:flex;align-items:center;gap:8px;padding:7px 3px;border-bottom:1px solid var(--bdr);cursor:pointer}
.xpi:hover{background:#f0f4ff}
.xpr{font-size:.88rem;font-weight:700;width:24px;text-align:center;color:#6c757d}
.xpi img{width:28px;height:28px;border-radius:50%;object-fit:cover;background:#eee;flex-shrink:0}
.xpn{font-weight:600;font-size:.85rem;color:var(--hdr)}
.xpl2{font-size:.72rem;color:#6c757d}
.xpst{display:flex;gap:10px}
